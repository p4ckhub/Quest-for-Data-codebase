{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "declarationMap": false
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "app/**/*.ts",
    "runner/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}