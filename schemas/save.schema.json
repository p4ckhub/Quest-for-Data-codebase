{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "save_version",
    "created_utc",
    "updated_utc",
    "player",
    "zones"
  ],
  "properties": {
    "save_version": { "type": "integer", "const": 1 },
    "created_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "updated_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "player": {
      "type": "object",
      "required": ["name", "class", "level", "xp"],
      "properties": {
        "name": { "type": "string" },
        "class": { "type": "string" },
        "level": { "type": "integer", "minimum": 0 },
        "xp": { "type": "integer", "minimum": 0 },
        "stats": {
          "type": "object",
          "required": ["hp", "mp", "str", "agi", "int"],
          "properties": {
            "hp": { "type": "integer", "minimum": 0 },
            "mp": { "type": "integer", "minimum": 0 },
            "str": { "type": "integer", "minimum": 0 },
            "agi": { "type": "integer", "minimum": 0 },
            "int": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "additionalProperties": false
    },
    "zones": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "enum": ["locked", "available", "passed", "completed"] },
            "lessons": {
              "type": "object",
              "patternProperties": {
                "^[a-z0-9_-]+$": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": { "enum": ["locked", "available", "passed", "completed"] },
                    "attempts": { "type": "integer", "minimum": 0 },
                    "player_region": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "spellbook": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lesson_id", "name", "signature", "source", "equipped"],
        "properties": {
          "lesson_id": { "type": "string" },
          "name": { "type": "string" },
          "signature": { "type": "string" },
          "source": { "type": "string" },
          "equipped": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "count"],
        "properties": {
          "item_id": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "settings_snapshot": {
      "type": "object",
      "properties": {
        "reduced_motion": { "type": "boolean" },
        "font_size": { "type": "integer", "minimum": 10, "maximum": 36 },
        "colorblind_palette": { "type": "boolean" },
        "animation_speed": { "type": "number", "minimum": 0.5, "maximum": 2.0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
